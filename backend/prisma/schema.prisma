generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  AGENT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
  LOST
}

enum PropertyCategory {
  RESIDENTIAL
  COMMERCIAL
}

enum PropertyPurpose {
  SALE
  RENT
}

enum AvailabilityStatus {
  AVAILABLE
  RESERVED
  SOLD
  RENTED
}

enum ClientType {
  BUYER
  SELLER
}

enum DealStage {
  INQUIRY
  NEGOTIATION
  AGREEMENT
  CLOSED
}

enum ActivityType {
  CALL
  EMAIL
  NOTE
  MEETING
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model User {
  id            String         @id @default(cuid())
  firstName     String
  lastName      String
  email         String         @unique
  phone         String?
  password      String
  role          Role
  isActive      Boolean        @default(true)
  avatarUrl     String?
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  assignedLeads Lead[]         @relation("LeadAssignedAgent")
  properties    Property[]     @relation("PropertyAssignedAgent")
  deals         Deal[]         @relation("DealAgent")
  tasks         Task[]         @relation("TaskAssignee")
  notifications Notification[]
  reports       ReportLog[]

  @@index([role, isActive])
}

model Lead {
  id                String         @id @default(cuid())
  fullName          String
  phone             String
  email             String?
  source            String
  budgetMin         Decimal?       @db.Decimal(12, 2)
  budgetMax         Decimal?       @db.Decimal(12, 2)
  preferredLocation String?
  propertyType      String?
  notes             String?
  status            LeadStatus     @default(NEW)
  followUpDate      DateTime?
  assignedAgentId   String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?
  assignedAgent     User?          @relation("LeadAssignedAgent", fields: [assignedAgentId], references: [id])
  activities        LeadActivity[]
  clients           Client[]

  @@index([status, source])
  @@index([assignedAgentId, followUpDate])
  @@index([createdAt])
}

model LeadActivity {
  id          String       @id @default(cuid())
  leadId      String
  type        ActivityType
  title       String
  description String?
  createdAt   DateTime     @default(now())
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}

model Property {
  id                 String             @id @default(cuid())
  title              String
  type               PropertyCategory
  purpose            PropertyPurpose
  price              Decimal            @db.Decimal(14, 2)
  location           String
  address            String
  latitude           Float?
  longitude          Float?
  size               Float?
  bedrooms           Int?
  bathrooms          Int?
  amenities          String[]
  description        String?
  availabilityStatus AvailabilityStatus @default(AVAILABLE)
  assignedAgentId    String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?
  assignedAgent      User?              @relation("PropertyAssignedAgent", fields: [assignedAgentId], references: [id])
  images             PropertyImage[]
  deals              Deal[]
  clients            Client[]           @relation("VisitedProperties")

  @@index([type, purpose, availabilityStatus])
  @@index([location, price])
  @@index([assignedAgentId])
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  altText    String?
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Client {
  id             String              @id @default(cuid())
  name           String
  phone          String
  email          String?
  type           ClientType
  preferences    String?
  budget         Decimal?            @db.Decimal(12, 2)
  linkedLeadId   String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?
  linkedLead     Lead?               @relation(fields: [linkedLeadId], references: [id])
  interactions   ClientInteraction[]
  visitedProps   Property[]          @relation("VisitedProperties")
  deals          Deal[]

  @@index([type, linkedLeadId])
}

model ClientInteraction {
  id          String       @id @default(cuid())
  clientId     String
  type        ActivityType
  title       String
  description String?
  createdAt   DateTime     @default(now())
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
}

model Deal {
  id                String       @id @default(cuid())
  clientId          String
  propertyId        String
  agentId           String
  dealValue         Decimal      @db.Decimal(14, 2)
  commissionPercent Decimal      @db.Decimal(5, 2)
  commissionAmount  Decimal      @db.Decimal(14, 2)
  stage             DealStage    @default(INQUIRY)
  expectedCloseDate DateTime?
  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  client            Client       @relation(fields: [clientId], references: [id])
  property          Property     @relation(fields: [propertyId], references: [id])
  agent             User         @relation("DealAgent", fields: [agentId], references: [id])
  documents         DealDocument[]

  @@index([stage, expectedCloseDate])
  @@index([agentId, createdAt])
}

model DealDocument {
  id         String   @id @default(cuid())
  dealId      String
  name       String
  fileUrl    String
  createdAt  DateTime @default(now())
  deal       Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  status      TaskStatus @default(PENDING)
  assigneeId  String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  assignee    User       @relation("TaskAssignee", fields: [assigneeId], references: [id])

  @@index([assigneeId, status])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  message     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

model ReportLog {
  id         String   @id @default(cuid())
  userId      String
  name       String
  format     String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
